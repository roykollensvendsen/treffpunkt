# Backend OAuth secrets for local `supabase start` (see ADR-0010).
#
# Copy this file to supabase/.env (gitignored) and fill in the values from your
# Google Cloud Console "Web application" OAuth client. `supabase start` resolves
# the env(...) references in supabase/config.toml from this file.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=your-client-secret
